# Copy this file to .env.local and set your own password.
# .env.local is git-ignored and will never be committed.
VITE_TASK_EDIT_PASSWORD=your-password-here

# Shared Task Management storage (server-side, for all users)
# Use Vercel KV environment variables in your deployment:
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
# Optional key override:
# TASKS_DATA_KEY=fsm:task-management
